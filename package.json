{
    "name": "messaging_app_back_end",
    "version": "1.0.0",
    "description": "An Express backend for a messaging app",
    "prisma": {
        "schema": "./prisma/schema.prisma"
    },
    "scripts": {
        "dev": "NODE_ENV=development && tsx --watch --env-file .env src/server.ts",
        "start": "NODE_ENV=production && node --env-file .env dist/server.js",
        "build": "tsc",
        "postinstall": "prisma generate",
        "test": "NODE_ENV=test && vitest",
        "test:run": "NODE_ENV=test && vitest --run",
        "test:ui": "NODE_ENV=test && vitest --ui",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "prisma:studio": "NODE_ENV=development && DATABASE_URL=postgresql://localhost:123@localhost:5432/messaging_app && npx prisma studio"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/IgnacioGandur/messaging_app_back_end.git"
    },
    "keywords": [],
    "author": "Ignacio Gandur",
    "license": "ISC",
    "type": "module",
    "bugs": {
        "url": "https://github.com/IgnacioGandur/messaging_app_back_end/issues"
    },
    "homepage": "https://github.com/IgnacioGandur/messaging_app_back_end#readme",
    "dependencies": {
        "@prisma/adapter-pg": "^7.7.0",
        "@quixo3/prisma-session-store": "^3.1.13",
        "@types/bcryptjs": "^2.4.6",
        "@types/cookie-parser": "^1.4.9",
        "@types/cors": "^2.8.19",
        "@types/express-session": "^1.18.2",
        "@types/multer": "^2.0.0",
        "@types/passport": "^1.0.17",
        "@types/passport-local": "^1.0.38",
        "@types/socket.io": "^3.0.1",
        "@types/supertest": "^6.0.3",
        "bcryptjs": "^3.0.2",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "express": "^5.1.0",
        "express-session": "^1.18.2",
        "express-validator": "^7.2.1",
        "multer": "^2.0.2",
        "passport": "^0.7.0",
        "passport-local": "^1.0.0",
        "pg": "^8.20.0",
        "socket.io": "^4.8.1",
        "supertest": "^7.1.4"
    },
    "devDependencies": {
        "@eslint/js": "^9.36.0",
        "@prisma/client": "^7.7.0",
        "@tsconfig/node22": "^22.0.2",
        "@types/express": "^5.0.3",
        "@types/node": "^24.6.1",
        "@vitest/coverage-v8": "^3.2.4",
        "@vitest/eslint-plugin": "^1.3.13",
        "@vitest/ui": "^3.2.4",
        "eslint": "^9.36.0",
        "eslint-plugin-perfectionist": "^4.15.0",
        "prettier": "^3.6.2",
        "prisma": "^7.7.0",
        "tsx": "^4.20.6",
        "typescript-eslint": "^8.45.0",
        "vitest": "^3.2.4"
    }
}
