{
  "name": "messaging_app_back_end",
  "version": "1.0.0",
  "description": "An Express backend for a messaging app",
  "scripts": {
    "dev": "tsx --watch --env-file .env src/index.ts",
    "start": "node --env-file .env dist/index.js",
    "build": "tsc",
    "test": "vitest",
    "test:run": "vitest --run",
    "test:ui": "vitest --ui",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IgnacioGandur/messaging_app_back_end.git"
  },
  "keywords": [],
  "author": "Ignacio Gandur",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/IgnacioGandur/messaging_app_back_end/issues"
  },
  "homepage": "https://github.com/IgnacioGandur/messaging_app_back_end#readme",
  "dependencies": {
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@tsconfig/node22": "^22.0.2",
    "@types/express": "^5.0.3",
    "@types/node": "^24.6.1",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/eslint-plugin": "^1.3.13",
    "@vitest/ui": "^3.2.4",
    "eslint": "^9.36.0",
    "eslint-plugin-perfectionist": "^4.15.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "typescript-eslint": "^8.45.0",
    "vitest": "^3.2.4"
  }
}
